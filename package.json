{
  "name": "utms",
  "private": true,
  "version": "0.0.0",
  "description": "Unified Test Management System monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @utms/web",
    "dev:api": "npm run dev -w @utms/api",
    "dev:worker": "npm run dev -w @utms/worker",
    "dev:runner": "npm run dev -w @utms/playwright-runner",
    "dev:all": "node scripts/development/dev-all.cjs",
    "backend": "npm run dev:api",
    "backend:self-check": "npm run self-check -w @utms/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @utms/web",
    "build:api": "npm run build -w @utms/api",
    "build:worker": "npm run build -w @utms/worker",
    "build:runner": "npm run build -w @utms/playwright-runner",
    "lint": "node scripts/verification/workspace-lint.cjs .",
    "format": "node scripts/verification/format-check.cjs . --write",
    "format:check": "node scripts/verification/format-check.cjs .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "architecture:check": "node scripts/verification/architecture-check.cjs",
    "test": "npm run test:unit && npm run test:contract",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "playwright test --project=api-integration",
    "test:e2e": "playwright test --project=e2e-chromium",
    "test:system": "playwright test --project=system-chromium",
    "test:security": "playwright test --project=security-chromium",
    "test:contract": "node scripts/verification/contract-tests.cjs",
    "test:smoke": "playwright test --project=smoke-chromium",
    "test:accessibility": "playwright test --project=accessibility-chromium",
    "test:compatibility": "node scripts/testing/compatibility.cjs",
    "test:performance": "playwright test --project=performance",
    "test:reliability": "playwright test --project=reliability",
    "test:regression": "playwright test --project=regression-chromium",
    "test:uat": "playwright test --project=uat-chromium",
    "test:structural": "playwright test --project=structural",
    "test:coverage": "c8 --all --reporter=text --reporter=html --reporter=json-summary --reports-dir=coverage --include=apps/web/src/utils/*.ts --include=apps/web/src/stores/authStore.ts --include=apps/web/src/services/workflowPolicyStore.ts --include=apps/api/src/modules/api-console/infrastructure/http/api-console-server.cjs playwright test --project=structural",
    "perf:stack:up": "node performance/scripts/stack.cjs up",
    "perf:stack:wait": "node performance/scripts/stack.cjs wait",
    "perf:stack:reset": "node performance/scripts/stack.cjs reset",
    "perf:stack:down": "node performance/scripts/stack.cjs down",
    "perf:smoke": "node performance/scripts/run-k6.cjs smoke",
    "perf:baseline": "node performance/scripts/run-k6.cjs baseline",
    "perf:load": "node performance/scripts/run-k6.cjs load",
    "perf:stress": "node performance/scripts/run-k6.cjs stress",
    "perf:spike": "node performance/scripts/run-k6.cjs spike",
    "perf:soak": "node performance/scripts/run-k6.cjs soak",
    "perf:breakpoint": "node performance/scripts/run-k6.cjs breakpoint",
    "perf:scalability": "node performance/scripts/run-k6.cjs scalability",
    "perf:recovery": "node performance/scripts/run-k6.cjs recovery",
    "perf:frontend": "node performance/scripts/run-k6.cjs frontend",
    "perf:report": "node performance/scripts/report.cjs",
    "perf:compare": "node performance/scripts/compare.cjs",
    "perf:all:safe": "npm run perf:smoke && npm run perf:baseline && npm run perf:load && npm run perf:spike && npm run perf:soak && npm run perf:scalability && npm run perf:recovery",
    "test:repeat": "node scripts/testing/repeat-critical.cjs",
    "test:all": "node scripts/testing/run-all.cjs",
    "test:stack:up": "node scripts/testing/stack.cjs up",
    "test:stack:wait": "node scripts/testing/stack.cjs wait",
    "test:stack:reset": "node scripts/testing/stack.cjs reset",
    "test:stack:seed": "node scripts/testing/stack.cjs seed",
    "test:stack:down": "node scripts/testing/stack.cjs down",
    "test:stack:clean": "node scripts/testing/stack.cjs clean",
    "test:docker": "node scripts/testing/docker-test.cjs",
    "db:generate": "node scripts/database/prisma-task.cjs generate",
    "db:migrate": "node scripts/database/prisma-task.cjs migrate",
    "db:migrate:status": "node scripts/database/prisma-task.cjs migrate:status",
    "db:seed": "node scripts/database/prisma-task.cjs seed",
    "db:verify": "node scripts/database/verify-database.cjs",
    "verify": "npm run format:check && npm run lint && npm run architecture:check && npm run typecheck && npm run test:unit && npm run test:contract && npm run build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.0",
    "@types/node": "22.19.17",
    "c8": "^10.1.3",
    "typescript": "5.9.3"
  }
}
