model User {
  id                      String                    @id @default(cuid())
  nationalCode            String?                   @unique @map("national_code") @db.VarChar(32)
  phoneNumber             String                    @unique @map("phone_number") @db.VarChar(32)
  fullName                String                    @map("full_name") @db.VarChar(255)
  email                   String?                   @unique @db.VarChar(320)
  isActive                Boolean                   @default(true) @map("is_active")
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  roleAssignments         UserRoleAssignment[]      @relation("UserAssignments")
  credential              UserCredential?
  passwordResetOtps       PasswordResetOtp[]
  sessions                UserSession[]
  requestedTestRequests   TestRequest[]             @relation("TestRequestRequester")
  assignedTestRequests    TestRequest[]             @relation("TestRequestAssignee")
  reviewedTestRequests    TestRequest[]             @relation("TestRequestReviewer")
  releaseDecisionRequests TestRequest[]             @relation("TestRequestReleaseDecisionBy")
  createdRequirements     Requirement[]             @relation("RequirementCreator")
  createdFlows            Flow[]                    @relation("FlowCreator")
  createdTestCases        TestCase[]                @relation("TestCaseCreator")
  executedRuns            TestRun[]                 @relation("TestRunExecutor")
  unlockedRuns            TestRun[]                 @relation("TestRunUnlocker")
  reportedBugs            Bug[]                     @relation("BugReporter")
  assignedBugs            Bug[]                     @relation("BugAssignee")
  unlockedBugs            Bug[]                     @relation("BugUnlocker")
  createdRetestTasks      RetestTask[]              @relation("RetestTaskCreator")
  assignedRetestTasks     RetestTask[]              @relation("RetestTaskAssignee")
  startedRetestTasks      RetestTask[]              @relation("RetestTaskStarter")
  reportedRunIssues       RunIssue[]                @relation("RunIssueReporter")
  assignedRunIssues       RunIssue[]                @relation("RunIssueAssignee")
  reviewedChecklists      Checklist[]               @relation("ChecklistReviewer")
  uploadedAttachments     Attachment[]              @relation("AttachmentUploader")
  triggeredPlaywrightRuns PlaywrightRun[]           @relation("PlaywrightRunTrigger")
  createdPlaywrightFiles  PlaywrightTestFile[]      @relation("PlaywrightFileCreator")
  qaReviewedVersions      VersionHistory[]          @relation("VersionHistoryQaReviewer")
  decidedVersions         VersionHistory[]          @relation("VersionHistoryDecisionBy")
  createdVersions         VersionHistory[]          @relation("VersionHistoryCreator")
  createdVersionRevisions VersionHistoryRevision[]  @relation("VersionHistoryRevisionCreator")
  auditLogs               AuditLog[]                @relation("AuditActor")
  comments                Comment[]                 @relation("CommentAuthor")
  notifications           Notification[]            @relation("NotificationRecipient")
  notificationOutboxItems NotificationOutboxItem[]  @relation("NotificationOutboxRecipient")
  commandTraces           CommandTrace[]            @relation("CommandTraceUser")
  updatedRunnerSettings   PlaywrightRunnerSetting[] @relation("PlaywrightRunnerUpdatedBy")
  reviewedSecurityReviews SecurityReview[]          @relation("SecurityReviewReviewer")
  scheduledReports        ScheduledReport[]         @relation("ScheduledReportOwner")
  reportAlerts            ReportAlert[]             @relation("ReportAlertOwner")

  @@index([isActive])
  @@map("users")
}

model UserCredential {
  userId       String   @id @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   @map("password_hash") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_credentials")
}

model PasswordResetOtp {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String    @map("code_hash") @db.Text
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)

  @@index([userId, expiresAt])
  @@map("password_reset_otps")
}

model UserSession {
  id                  String              @id @default(cuid())
  userId              String              @map("user_id")
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignmentId        String?             @map("assignment_id")
  assignment          UserRoleAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  contextId           String              @map("context_id")
  role                UserRole
  scope               AccessScope
  applicationId       String?             @map("application_id")
  application         Application?        @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  scopeApplicationIds String[]            @default([]) @map("scope_application_ids")
  tokenHash           String              @map("token_hash") @db.Text
  userAgent           String?             @map("user_agent") @db.Text
  ipAddress           String?             @map("ip_address") @db.Inet
  expiresAt           DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt           DateTime?           @map("revoked_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, revokedAt])
  @@index([contextId])
  @@map("user_sessions")
}

model WorkflowPolicy {
  id                             String                     @id
  name                           String                     @db.VarChar(255)
  description                    String                     @db.Text
  versionHistoryMode             VersionHistoryWorkflowMode @map("version_history_mode")
  qaReviewOwnerLabel             String                     @map("qa_review_owner_label") @db.VarChar(255)
  decisionOwnerLabel             String                     @map("decision_owner_label") @db.VarChar(255)
  requireIndependentDecisionRole Boolean                    @default(false) @map("require_independent_decision_role")
  capabilityRoles                Json                       @default("{}") @map("capability_roles")
  createdAt                      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  applications                   Application[]

  @@map("workflow_policies")
}

model Application {
  id                    String                           @id @default(cuid())
  name                  String                           @db.VarChar(255)
  code                  String                           @unique @db.VarChar(80)
  description           String?                          @db.Text
  cdeFrontUrl           String?                          @map("cde_front_url") @db.Text
  cdeDataServiceUrl     String?                          @map("cde_data_service_url") @db.Text
  cdeGatewayUrl         String?                          @map("cde_gateway_url") @db.Text
  workflowPolicyId      String?                          @map("workflow_policy_id")
  workflowPolicy        WorkflowPolicy?                  @relation(fields: [workflowPolicyId], references: [id], onDelete: SetNull)
  isActive              Boolean                          @default(true) @map("is_active")
  createdAt             DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)
  roleAssignments       UserRoleAssignment[]             @relation("AssignmentDefaultApplication")
  assignmentScopes      UserRoleAssignmentApplication[]
  sessions              UserSession[]
  testRequests          TestRequest[]
  requirements          Requirement[]
  testCases             TestCase[]
  testRuns              TestRun[]
  bugs                  Bug[]
  retestTasks           RetestTask[]
  runIssues             RunIssue[]
  checklists            Checklist[]
  securityReviews       SecurityReview[]
  playwrightRuns        PlaywrightRun[]
  playwrightTestFolders PlaywrightTestFolder[]
  playwrightTestFiles   PlaywrightTestFile[]
  hiddenPlaywrightPaths PlaywrightHiddenDiscoveredPath[]
  versionHistories      VersionHistory[]
  auditLogs             AuditLog[]
  commandTraces         CommandTrace[]
  apiCollections        ApiConsoleCollection[]
  apiRequests           ApiConsoleRequest[]
  apiShareRequests      ApiShareRequest[]
  apiConsumers          ApiVersionConsumer[]
  apiReferences         ApiConsoleReference[]
  apiUsageEvents        ApiUsageEvent[]
  scheduledReports      ScheduledReport[]
  reportAlerts          ReportAlert[]

  @@index([isActive])
  @@map("applications")
}

model UserRoleAssignment {
  id                    String                          @id @default(cuid())
  userId                String                          @map("user_id")
  user                  User                            @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  applicationId         String                          @map("application_id")
  application           Application                     @relation("AssignmentDefaultApplication", fields: [applicationId], references: [id], onDelete: Restrict)
  applications          UserRoleAssignmentApplication[]
  role                  UserRole
  scope                 AccessScope
  automatedTestsEnabled Boolean                         @default(false) @map("automated_tests_enabled")
  isActive              Boolean                         @default(true) @map("is_active")
  createdAt             DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions              UserSession[]

  @@index([userId, role, isActive])
  @@index([applicationId, role])
  @@map("user_role_assignments")
}

model UserRoleAssignmentApplication {
  assignmentId  String             @map("assignment_id")
  applicationId String             @map("application_id")
  assignment    UserRoleAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([assignmentId, applicationId])
  @@index([applicationId])
  @@map("user_role_assignment_applications")
}

model TestRequest {
  id                      String                   @id @default(cuid())
  applicationId           String                   @map("application_id")
  application             Application              @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  title                   String                   @db.VarChar(500)
  description             String                   @db.Text
  version                 String                   @db.VarChar(64)
  buildNumber             String?                  @map("build_number") @db.VarChar(64)
  environment             String                   @db.VarChar(120)
  priority                Priority
  riskLevel               Priority                 @map("risk_level")
  status                  TestRequestStatus
  systemUrl               String?                  @map("system_url") @db.Text
  testTypes               TestType[]               @default([]) @map("test_types")
  requesterId             String                   @map("requester_id")
  requester               User                     @relation("TestRequestRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  assigneeId              String?                  @map("assignee_id")
  assignee                User?                    @relation("TestRequestAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  requirementId           String?                  @map("requirement_id")
  requirement             Requirement?             @relation("TestRequestPrimaryRequirement", fields: [requirementId], references: [id], onDelete: SetNull)
  reviewedAt              DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  reviewedById            String?                  @map("reviewed_by_id")
  reviewedBy              User?                    @relation("TestRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes             String?                  @map("review_notes") @db.Text
  submittedAt             DateTime?                @map("submitted_at") @db.Timestamptz(6)
  versionHistoryId        String?                  @map("version_history_id")
  versionHistory          VersionHistory?          @relation("TestRequestCurrentVersionHistory", fields: [versionHistoryId], references: [id], onDelete: SetNull)
  qaQualityStatus         QAQualityStatus?         @map("qa_quality_status")
  qaQualityNotes          String?                  @map("qa_quality_notes") @db.Text
  releaseDecision         VersionHistoryDecision?  @map("release_decision")
  releaseDecisionReason   String?                  @map("release_decision_reason") @db.Text
  releaseDecisionById     String?                  @map("release_decision_by_id")
  releaseDecisionBy       User?                    @relation("TestRequestReleaseDecisionBy", fields: [releaseDecisionById], references: [id], onDelete: SetNull)
  releaseDecisionAt       DateTime?                @map("release_decision_at") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  selectedRequirements    TestRequestRequirement[]
  originatedRequirements  Requirement[]            @relation("RequirementOriginRequest")
  testCases               TestCase[]
  testRuns                TestRun[]
  retestTasks             RetestTask[]
  checklists              Checklist[]
  playwrightRuns          PlaywrightRun[]
  primaryVersionHistories VersionHistory[]         @relation("VersionHistoryPrimaryRequest")
  versionHistoryLinks     VersionHistoryRequest[]

  @@index([applicationId, status])
  @@index([requesterId])
  @@index([assigneeId])
  @@index([version, buildNumber])
  @@map("test_requests")
}

model TestRequestRequirement {
  testRequestId String      @map("test_request_id")
  requirementId String      @map("requirement_id")
  testRequest   TestRequest @relation(fields: [testRequestId], references: [id], onDelete: Cascade)
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([testRequestId, requirementId])
  @@index([requirementId])
  @@map("test_request_requirements")
}

model Requirement {
  id                     String                   @id @default(cuid())
  applicationId          String                   @map("application_id")
  application            Application              @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  title                  String                   @db.VarChar(500)
  description            String                   @db.Text
  acceptanceCriteria     String?                  @map("acceptance_criteria") @db.Text
  riskNotes              String?                  @map("risk_notes") @db.Text
  status                 RequirementStatus
  isActive               Boolean                  @default(true) @map("is_active")
  createdById            String                   @map("created_by_id")
  createdBy              User                     @relation("RequirementCreator", fields: [createdById], references: [id], onDelete: Restrict)
  testRequestId          String?                  @map("test_request_id")
  testRequest            TestRequest?             @relation("RequirementOriginRequest", fields: [testRequestId], references: [id], onDelete: SetNull)
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  flows                  Flow[]
  testCases              TestCase[]
  primaryForTestRequests TestRequest[]            @relation("TestRequestPrimaryRequirement")
  requestLinks           TestRequestRequirement[]

  @@index([applicationId, status, isActive])
  @@index([createdById])
  @@map("requirements")
}

model Flow {
  id            String      @id @default(cuid())
  requirementId String      @map("requirement_id")
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title         String      @db.VarChar(500)
  description   String      @db.Text
  steps         String?     @db.Text
  createdById   String      @map("created_by_id")
  createdBy     User        @relation("FlowCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  testCases     TestCase[]

  @@index([requirementId])
  @@map("flows")
}

model TestCase {
  id                   String                @id @default(cuid())
  applicationId        String                @map("application_id")
  application          Application           @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  testRequestId        String?               @map("test_request_id")
  testRequest          TestRequest?          @relation(fields: [testRequestId], references: [id], onDelete: SetNull)
  requirementId        String                @map("requirement_id")
  requirement          Requirement           @relation(fields: [requirementId], references: [id], onDelete: Restrict)
  flowId               String?               @map("flow_id")
  flow                 Flow?                 @relation(fields: [flowId], references: [id], onDelete: SetNull)
  title                String                @db.VarChar(500)
  scenario             String                @db.Text
  preconditions        String                @db.Text
  testData             String                @map("test_data") @db.Text
  steps                String                @db.Text
  expectedResult       String                @map("expected_result") @db.Text
  testType             TestType              @map("test_type")
  testDesignTechnique  TestDesignTechnique   @map("test_design_technique")
  testDesignTechniques TestDesignTechnique[] @default([]) @map("test_design_techniques")
  priority             Priority
  riskLevel            Priority              @map("risk_level")
  qualityAttribute     QualityAttribute      @map("quality_attribute")
  automationCandidate  Boolean               @default(false) @map("automation_candidate")
  regressionCandidate  Boolean               @default(false) @map("regression_candidate")
  isActive             Boolean               @default(true) @map("is_active")
  isComplete           Boolean               @default(false) @map("is_complete")
  readinessErrors      String[]              @default([]) @map("readiness_errors")
  status               TestCaseStatus
  createdById          String                @map("created_by_id")
  createdBy            User                  @relation("TestCaseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  testRuns             TestRun[]
  retestTasks          RetestTask[]
  securityReviews      SecurityReview[]

  @@index([applicationId, status, isActive])
  @@index([requirementId])
  @@index([testRequestId])
  @@map("test_cases")
}

model TestRun {
  id                       String           @id @default(cuid())
  testCaseId               String           @map("test_case_id")
