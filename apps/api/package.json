{
  "name": "@utms/api",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "node src/main.cjs",
    "build": "tsc -p tsconfig.json --noEmit && node -e \"const s=require('./src/modules/api-console/infrastructure/http/api-console-server.cjs'); if (!s.createServer) process.exit(1);\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "self-check": "node -e \"const s=require('./src/modules/api-console/infrastructure/http/api-console-server.cjs'); s.runSelfCheck().then(r=>{console.log(JSON.stringify(r,null,2)); process.exit(r.failed?1:0);}).catch(e=>{console.error(e); process.exit(1);})\"",
    "test": "npm run self-check",
    "test:unit": "npm run self-check",
    "lint": "node ../../scripts/verification/workspace-lint.cjs apps/api",
    "format:check": "node ../../scripts/verification/format-check.cjs apps/api"
  }
}
